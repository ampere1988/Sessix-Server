{
  "name": "sessix-server",
  "version": "0.2.8",
  "bin": {
    "sessix-server": "./dist/index.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.js"
    },
    "./cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "bonjour-service": "^1.3.0",
    "chokidar": "^4.0.0",
    "uuid": "^11.1.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@sessix/shared": "*",
    "@types/ws": "^8.5.0",
    "@types/uuid": "^10.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "tsup": "^8.0.0"
  }
}
